#!/usr/bin/env bash
set -euo pipefail

export HOME="${HOME:-/home/orbit}"
export DISPLAY="${DISPLAY:-:1}"

mkdir -p "${HOME}/.vnc"

for _ in {1..100}; do
  if [[ -S /tmp/.X11-unix/X1 ]]; then
    break
  fi
  sleep 0.1
done

if [[ -n "${VNC_PASSWORD:-}" ]]; then
  x11vnc -storepasswd "${VNC_PASSWORD}" "${HOME}/.vnc/passwd" >/dev/null
  exec x11vnc \
    -display "${DISPLAY}" \
    -forever \
    -shared \
    -rfbport 5901 \
    -rfbauth "${HOME}/.vnc/passwd" \
    -xkb
fi

exec x11vnc \
  -display "${DISPLAY}" \
  -forever \
  -shared \
  -rfbport 5901 \
  -nopw \
  -xkb
