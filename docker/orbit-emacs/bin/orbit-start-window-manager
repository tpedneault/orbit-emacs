#!/usr/bin/env bash
set -euo pipefail

export HOME="${ORBIT_HOME:-/home/orbit}"
export DISPLAY="${DISPLAY:-:1}"

for _ in {1..100}; do
  if xdpyinfo -display "${DISPLAY}" >/dev/null 2>&1; then
    break
  fi
  sleep 0.1
done

xset r on || true
xset r rate "${KEY_REPEAT_DELAY:-250}" "${KEY_REPEAT_RATE:-45}" || true

exec openbox
