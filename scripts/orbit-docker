#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
COMPOSE_FILE="${REPO_ROOT}/docker-compose.yml"
SERVICE="orbit-emacs"

compose() {
  if docker compose version >/dev/null 2>&1; then
    docker compose -f "${COMPOSE_FILE}" "$@"
  elif command -v docker-compose >/dev/null 2>&1; then
    docker-compose -f "${COMPOSE_FILE}" "$@"
  else
    echo "docker compose is not available" >&2
    exit 1
  fi
}

abs_path() {
  local path="${1}"
  if command -v realpath >/dev/null 2>&1; then
    realpath "${path}"
  else
    (cd "${path}" && pwd)
  fi
}

host_uid() {
  if command -v id >/dev/null 2>&1; then
    id -u
  else
    printf '1000\n'
  fi
}

host_gid() {
  if command -v id >/dev/null 2>&1; then
    id -g
  else
    printf '1000\n'
  fi
}

usage() {
  cat <<'EOF'
Usage:
  scripts/orbit-docker build
  scripts/orbit-docker up [PROJECT_DIR]
  scripts/orbit-docker shell
  scripts/orbit-docker logs
  scripts/orbit-docker stop

Environment:
  EMACS_VERSION   Emacs version to build, default 30.2
  ORBIT_VNC_PORT  Host VNC port, default 5901
  VNC_GEOMETRY    Virtual display size, default 1920x1080
  VNC_PASSWORD    Optional VNC password
EOF
}

command="${1:-}"
case "${command}" in
  build)
    export ORBIT_UID="${ORBIT_UID:-$(host_uid)}"
    export ORBIT_GID="${ORBIT_GID:-$(host_gid)}"
    compose build "${SERVICE}"
    ;;
  up)
    project="${2:-$(pwd)}"
    export ORBIT_WORKSPACE="$(abs_path "${project}")"
    export ORBIT_UID="${ORBIT_UID:-$(host_uid)}"
    export ORBIT_GID="${ORBIT_GID:-$(host_gid)}"
    compose up -d "${SERVICE}"
    echo "Orbit Emacs VNC is available at localhost:${ORBIT_VNC_PORT:-5901}"
    echo "Workspace mounted at /workspace from ${ORBIT_WORKSPACE}"
    ;;
  shell)
    compose exec "${SERVICE}" bash
    ;;
  logs)
    compose logs -f "${SERVICE}"
    ;;
  stop)
    compose stop "${SERVICE}"
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    echo "Unknown command: ${command}" >&2
    usage >&2
    exit 1
    ;;
esac
